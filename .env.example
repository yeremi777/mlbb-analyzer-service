HOST=127.0.0.1
PORT=8000
RELOAD=true

# Comma-separated browser origins (local dev origin is always allowed).
FRONTEND_ORIGIN=https://your-frontend.vercel.app

AI_PROVIDER=openrouter
AI_TIMEOUT_SECONDS=20

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

OPENROUTER_API_KEY=<YOUR_OPENROUTER_API_KEY>
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SERVER_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_TITLE=MLBB Analyzer Service
OPENROUTER_HTTP_REFERER=http://127.0.0.1:8000

# Redis configuration for caching and rate limiting
# Use url for hosted Redis providers. If url is set, it overrides host/port/db.
REDIS_URL=redis://:127.0.0.1:6379/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Rate limiting settings
RATE_LIMIT_ENABLED=false
RATE_LIMIT_ANALYZE_MAX_REQUESTS=5
RATE_LIMIT_ANALYZE_WINDOW_SECONDS=18000
RATE_LIMIT_ANALYZE_DETAIL_MULTIPLIER=3
RATE_LIMIT_COOKIE_NAME=mlbb_analyzer_client_id
RATE_LIMIT_COOKIE_MAX_AGE_SECONDS=2592000
# Use RATE_LIMIT_COOKIE_SECURE=true and RATE_LIMIT_COOKIE_SAMESITE=none for HTTPS
# frontend/backend deployments on separate domains.
RATE_LIMIT_COOKIE_SECURE=false
RATE_LIMIT_COOKIE_SAMESITE=lax
RATE_LIMIT_SALT=change-this-to-a-random-secret
